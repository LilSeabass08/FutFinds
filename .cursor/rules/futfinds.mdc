│
├── types/                      # TypeScript interfaces
│   └── index.ts
│
├── styles/                     # All stylesheets — never put styles elsewhere
│   ├── theme.ts                # Global design tokens: colors, spacing, typography
│   ├── components/             # One stylesheet per component
│   │   ├── GameCard.styles.ts
│   │   ├── GameForm.styles.ts
│   │   └── ...
